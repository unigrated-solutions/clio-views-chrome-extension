{
  "manifest_version": 3,
  "name": "Clio Table Views",
  "version": "0.4.0",
  "description": "Save and apply custom column visibility views for Clio Contacts and Matters tables.",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "sidePanel"],
  "host_permissions": [
    "https://app.clio.com/*",
    "https://*.clio.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open Clio Table Views"
  },
  "side_panel": {
    "default_path": "panel.html"
  }
}